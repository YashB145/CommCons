<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E2A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Join SevaLink"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#00E5FF"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create your account to get started"
            android:textSize="14sp"
            android:textColor="#7986CB"
            android:layout_marginBottom="36dp"/>

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Full Name"
            android:textColor="#FFFFFF"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="#1A1F4A"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Email Address"
            android:textColor="#FFFFFF"
            android:inputType="textEmailAddress"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="#1A1F4A"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Password"
            android:textColor="#FFFFFF"
            android:inputType="textPassword"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="#1A1F4A"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="I am a..."
            android:textSize="14sp"
            android:textColor="#7986CB"
            android:layout_marginBottom="12dp"/>

        <RadioGroup
            android:id="@+id/roleGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="28dp">

            <RadioButton
                android:id="@+id/rbVolunteer"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Volunteer"
                android:textColor="#FFFFFF"
                android:buttonTint="#00E5FF"
                android:gravity="center_vertical"
                android:layout_marginEnd="8dp"
                android:paddingStart="12dp"
                android:background="#1A1F4A"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/rbNgo"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="NGO"
                android:textColor="#FFFFFF"
                android:buttonTint="#00E5FF"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:background="#1A1F4A"/>
        </RadioGroup>

        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Create Account"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#0A0E2A"
            android:backgroundTint="#00E5FF"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnGoToLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Already have an account? Sign In"
            android:textSize="14sp"
            android:textColor="#00E5FF"
            android:backgroundTint="#1A1F4A"/>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            android:indeterminateTint="#00E5FF"/>

    </LinearLayout>
</ScrollView>