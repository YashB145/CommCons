<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E2A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:minHeight="700dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🤝"
            android:textSize="64sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SevaLink"
            android:textSize="38sp"
            android:textStyle="bold"
            android:textColor="#00E5FF"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connecting volunteers with purpose"
            android:textSize="14sp"
            android:textColor="#7986CB"
            android:layout_marginBottom="48dp"/>

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Email Address"
            android:textColorHint="#7986CB"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:inputType="textEmailAddress"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="#1A1F4A"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Password"
            android:textColor="#FFFFFF"
            android:textColorHint="#7986CB"
            android:textSize="15sp"
            android:inputType="textPassword"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="#1A1F4A"
            android:layout_marginBottom="28dp"/>

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Sign In"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#0A0E2A"
            android:backgroundTint="#00E5FF"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnGoToRegister"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Create Account"
            android:textSize="15sp"
            android:textColor="#00E5FF"
            android:backgroundTint="#1A1F4A"
            android:layout_marginBottom="16dp"/>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:indeterminateTint="#00E5FF"/>

    </LinearLayout>
</ScrollView>