<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/screenBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:minHeight="700dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🤝"
            android:textSize="64sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SevaLink"
            android:textSize="38sp"
            android:textStyle="bold"
            android:textColor="?attr/accentCyan"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connecting volunteers with purpose"
            android:textSize="14sp"
            android:textColor="?attr/secondaryText"
            android:layout_marginBottom="48dp"/>

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Email Address"
            android:textColor="?attr/primaryText"
            android:textColorHint="?attr/secondaryText"
            android:textSize="15sp"
            android:inputType="textEmailAddress"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="?attr/inputBackground"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Password"
            android:textColor="?attr/primaryText"
            android:textColorHint="?attr/secondaryText"
            android:textSize="15sp"
            android:inputType="textPassword"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="?attr/inputBackground"
            android:layout_marginBottom="28dp"/>

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Sign In"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="?attr/screenBackground"
            android:backgroundTint="?attr/accentCyan"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnGoToRegister"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Create Account"
            android:textSize="15sp"
            android:textColor="?attr/accentCyan"
            android:backgroundTint="?attr/cardBackground"
            android:layout_marginBottom="16dp"/>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:indeterminateTint="?attr/accentCyan"/>

    </LinearLayout>
</ScrollView>