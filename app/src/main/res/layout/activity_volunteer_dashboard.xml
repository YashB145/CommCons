<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/screenBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="?attr/headerBackground"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SevaLink Volunteer"
                    android:textSize="12sp"
                    android:textColor="?attr/secondaryText"/>

                <TextView
                    android:id="@+id/tvWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome!"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="?attr/primaryText"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnSettings"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="⚙️"
                android:textSize="16sp"
                android:backgroundTint="?attr/buttonBackground"
                android:textColor="?attr/accentCyan"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Logout"
                android:textSize="12sp"
                android:backgroundTint="?attr/buttonBackground"
                android:textColor="?attr/accentCyan"/>
        </LinearLayout>

        <!-- Stats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/cardBackground"
                android:layout_marginEnd="8dp">

                <TextView
                    android:id="@+id/tvTasksAvailable"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:textColor="?attr/accentCyan"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Available"
                    android:textSize="12sp"
                    android:textColor="?attr/secondaryText"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/cardBackground">

                <TextView
                    android:id="@+id/tvTasksAccepted"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:textColor="?attr/accentGreen"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Accepted"
                    android:textSize="12sp"
                    android:textColor="?attr/secondaryText"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="QUICK ACTIONS"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="?attr/secondaryText"
            android:letterSpacing="0.15"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="12dp"/>

        <!-- Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="10dp">

            <Button
                android:id="@+id/btnViewTasks"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="📋 View Tasks"
                android:backgroundTint="?attr/buttonBackground"
                android:textColor="?attr/accentCyan"
                android:textSize="13sp"/>

            <Button
                android:id="@+id/btnViewMap"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:text="🗺 Map View"
                android:backgroundTint="?attr/buttonBackground"
                android:textColor="?attr/accentGreen"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="10dp">

            <Button
                android:id="@+id/btnChat"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="💬 Chat"
                android:backgroundTint="?attr/buttonBackground"
                android:textColor="?attr/accentOrange"
                android:textSize="13sp"/>

            <Button
                android:id="@+id/btnProfile"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:text="👤 My Profile"
                android:backgroundTint="?attr/buttonBackground"
                android:textColor="?attr/accentYellow"
                android:textSize="13sp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnSmartMatch"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="🤖 Gemini Smart Match"
            android:backgroundTint="?attr/accentCyan"
            android:textColor="?attr/screenBackground"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btnHistory"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📋 Task History"
            android:backgroundTint="?attr/cardBackground"
            android:textColor="?attr/accentCyan"
            android:textSize="15sp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>